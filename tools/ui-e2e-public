#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

platform=""

usage() {
  cat >&2 <<USAGE
usage: ./tools/ui-e2e-public --platform ios|android|all
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --platform)
      platform="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

if [ -z "$platform" ]; then
  usage
  exit 2
fi

case "$platform" in
  all)
    exec cargo test -p pikahut --test integration_public ui_e2e_public_all -- --ignored --nocapture
    ;;
  ios)
    exec cargo test -p pikahut --test integration_public ui_e2e_public_ios -- --ignored --nocapture
    ;;
  android)
    exec cargo test -p pikahut --test integration_public ui_e2e_public_android -- --ignored --nocapture
    ;;
  *)
    echo "error: invalid --platform: $platform" >&2
    exit 2
    ;;
esac
